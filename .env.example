# OpenHands Agent Server URL (for example: http://localhost:8000)
OPENHANDS_BASE_URL=

# LLM config passed to OpenHands when creating a conversation
OPENHANDS_LLM_MODEL=
OPENHANDS_LLM_API_KEY=

# Optional settings
OPENHANDS_LLM_BASE_URL=
OPENHANDS_SESSION_API_KEY=
OPENHANDS_TIMEOUT_MS=25000
OPENHANDS_WORKING_DIR=/tmp
